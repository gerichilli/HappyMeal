                        .btn.button-next
                            +iconSVG('chevron-right', 'icon icon-dark')
                        .btn.button-prev
                            +iconSVG('chevron-left', 'icon icon-dark')
                .section__footer 
                    a(role="button" href="#").btn.btn-medium.btn-outline See more

        section.section#side-dishes 
            .container
                .section__header.section__header--baseline 
                    h2.section__heading Side Dishes
                    p.section__sub-heading these recipes will help you meal plan like never before.
                .section__body
                    .sidedish
                        .sidedish__image 
                            img(src="./images/sidedishes.png", alt="Side dishes banner")
                        .sidedish__list 
                            .recipe__wrapper.recipe__wrapper--wrap
                                - imgSrc = "./images/sections/sidedishes/01.png"
                                - title = "French Bread Pizzas"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')

                                - imgSrc = "./images/sections/sidedishes/02.png"
                                - title = "Chocolate, Banana and you"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')

                                - imgSrc = "./images/sections/sidedishes/03.png"
                                - title = "Stuffed cabbage rolls"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')
                                
                                .w-100
                            
                                - imgSrc = "./images/sections/sidedishes/04.png"
                                - title = "Buffalo Chicken Salad"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')

                                - imgSrc = "./images/sections/sidedishes/05.png"
                                - title = "Chicken Caesar Soup"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')

                                - imgSrc = "./images/sections/sidedishes/06.png"
                                - title = "Turkey Cobb Sandwich"
                                +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, false, 'col-4')

        section.section.cta#join-us
            .container
                .cta__wrapper 
                    .cta__heading See why over 
                        span 250,000+ 
                        | users <br>
                        | have joined HappyMeal
                    form(action="#").cta__form.join-form
                        input(type="email" placeholder="Email Address")
                        button.btn Get Started
                    .cta__bottom 100% FREE. No Spam. No Affiliate Links. No data sharing.
                    

        include includes/snsSection.pug

    include includes/footer.pug


