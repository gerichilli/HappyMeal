include includes/mixins/svg.pug
include includes/mixins/recipe.pug

doctype html(lang="en")
include includes/head.pug
    title Happy Meal - Recipes for everyone
body
    include includes/header.pug
    include includes/banner.pug

    main 
        section.section#recently-update 
            .container
                .section__header 
                    h2.section__heading
                        +iconSVG('clock', 'icon icon-medium')
                        span recently update   
                    a(role="button" href="#").section__more 
                        span.text See more
                        +iconSVG('arrow-right', 'icon icon-small icon-orange')
                .section__body
                    .recipe__slideshow
                        //- .loading
                        //-     img(src="images/food_loader.gif", alt="Loading")
                        //-     span Loading...
                        .swiper.product-swiper-large.recipe-container
                            .recipe__wrapper.swiper-wrapper

                        .btn.button-next
                            +iconSVG('chevron-right', 'icon icon-dark')
                        .btn.button-prev
                            +iconSVG('chevron-left', 'icon icon-dark')
                
        section.section#vegetarianism 
            .container
                .section__header.section__header--baseline 
                    h2.section__heading Vegetarianism
                    p.section__sub-heading Find healthy, delicious weight-loss and diet recipes 

                    a(role="button" href="#").section__more 
                        span.text See more
                        +iconSVG('arrow-right', 'icon icon-small icon-orange')
                .section__body
                    .recipe__slideshow
                        .swiper.product-swiper-large.recipe-container
