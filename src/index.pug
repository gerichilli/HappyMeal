                                //- - imgSrc = "./images/sections/vegetarianism/03.png"
                                //- - title = "Almond, Kale, and Banana Smoothie"
                                //- - ingreCount = 13
                                //- +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, true)

