                        .btn.button-next
                            +iconSVG('chevron-right', 'icon icon-dark')
                        .btn.button-prev
                            +iconSVG('chevron-left', 'icon icon-dark')
                
        section.section.event#event 
            .container 
                .event__description 
                    h2.event__heading Greek Cooking Workshop
                    p.event__details. 
                        Join us for a celebration of Greek seasonal 
                        cooking and warm Greek hospitality - it would't 
                        be a Greek feast without lots of food 
                        and drinks on offer, would it?
                    .event__tags 
                        span.event__tag #2021-10-20
                        span.event__tag.event__tag--bold #Chef Despina Siahuli
                        span.event__tag #Traditional Greek pies
            .event__img 
            .event__cta 
                .event__card
                    h3.text-uppercase Greek Cooking Workshop
                    .event__info 
                        div Date
                        .event__info-main 2021-10-20
                    .event__info 
                        div Time
                        .event__info-main 13:00
                    .event__info 
                        div Place
                        .event__info-main 1651 High Meadow Lane
                    button.btn.btn-primary.event__btn Follow this Event

        section.section#healthy 
            .container
                .section__header.section__header--baseline 
                    h2.section__heading Healthy Eating
                    p.section__sub-heading Creative recipes to make life more fun
                .section__body
                    .recipe__slideshow
                        .swiper.product-swiper-medium.recipe-container
                            .recipe__wrapper.swiper-wrapper
                                //- - imgSrc = ""
                                //- - title = ""
                                //- - bookmarkSize = 'inside'
                                //- - tags = []
                                //- +recipeItem({link: link, imgSrc: imgSrc, title: title, ingreCount: ingreCount, tags: tags, bookmarkSize: bookmarkSize, iconClasses: iconClasses}, true)
                                
                                //- - imgSrc = ""
                                //- - title = ""
                                //- - ingreCount = ""
                                //- - tags = []
